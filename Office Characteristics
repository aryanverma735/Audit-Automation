select 
case WHEN  count(*) > 0
  THEN 'Audit Pass'
  ELSE 'Audit Fail'
END as Audit_Status
from
(SELECT *
FROM PROV P
JOIN POA  A
  ON A.MSTR_PROV_ID = P.MSTR_PROV_ID
JOIN POFC_CHARSTC PC
  ON PC.POA_KEY = A.POA_KEY
JOIN CD_VAL CC 
  ON PC.OFC_CHARSTC_TYPE_CD = CC.CD_VAL_CD
JOIN CD_VAL CO
   ON PC.OFC_CHARSTC_CTGRY_CD = CO.CD_VAL_CD    
 

WHERE P.NPI = '1942583455'
AND A.POA_KEY = '6011624625'
AND CO.CD_VAL_NM = 'Facility Bed Type'
AND PC.POFC_CHARSTC_EFCTV_DT = TO_DATE('04/27/2026','MM/DD/YYYY')
AND CC.CD_VAL_NM = 'Assisted Living Beds'
AND PC.DIR_DSPLY_IND = 'Y'
)
