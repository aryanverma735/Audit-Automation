SELECT CASE
         WHEN EXISTS (
                SELECT 1
                FROM PROV P
                WHERE P.MSTR_PROV_ID = '1104365085'
                  AND UPPER(P.PROV_ORG_NM) = UPPER('EOH Acquisition Group LLC')
              )
          AND EXISTS (
                SELECT 1
                FROM POA P
                WHERE P.MSTR_PROV_ID = '1104365085'
                  AND UPPER(P.PROV_DBA_NM) = UPPER('Carewell Health')
              )
         THEN 'Audit Pass'
         ELSE 'Audit Fail'
       END AS audit_result
FROM DUAL;
