WITH CTE AS(
SELECT * FROM 
PROV_SPCLTY P
JOIN CD_VAL C
ON P.SPCLTY_CD = C.CD_VAL_CD
WHERE 
P.MSTR_PROV_ID = '1105780149'
AND C.CD_VAL_NM = 'Lactation Consultant'
AND P.PROV_SPCLTY_EFCTV_DT = TO_DATE('01/01/1901', 'MM/DD/YYYY')
AND P.PROV_DATA_CRDNTLD_IND = 'N'
)
SELECT 
CASE WHEN COUNT(*) > 0 THEN 'Audit Pass' ELSE 'Audit Fail' END AS Audit_result 
FROM CTE
