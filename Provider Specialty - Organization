WITH CTE AS
(SELECT *
FROM PROV P
JOIN PROV_SPCLTY PS
  ON P.MSTR_PROV_ID = PS.MSTR_PROV_ID
JOIN CD_VAL C 
  ON PS.SPCLTY_CD = C.CD_VAL_CD
JOIN CD_VAL CC
  ON PS.PROV_SPCLTY_SOR_CD = CC.CD_VAL_CD
 
WHERE P.MSTR_PROV_ID = '1103258756'
  AND C.CD_VAL_NM = 'Facility Professional Services'
  AND CC.CD_VAL_NM = 'Facets Provider')
 
SELECT 
CASE WHEN COUNT(*) > 0 THEN 'Audit Pass' ELSE 'Audit Fail' END AS Audit_result 
FROM CTE
